/* 首页样式 */
page {
  height: 100%;
  background-color: #f0f9f4;
}
.container {
  min-height: 100vh;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.header-deco {
  height: 260rpx;
  background: linear-gradient(180deg, #b7e4c7 0%, #f0f9f4 100%);
  border-radius: 0 0 60% 60%;
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 0;
}

.title-section {
  position: relative;
  z-index: 1;
  text-align: center;
  padding-top: 60rpx;
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #2d6a4f;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #52b788;
}

.dish-show-area {
  position: relative;
  z-index: 1;
  height: 500rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 32rpx;
}

.dish-card {
  text-align: center;
  width: 100%;
}

.dish-image {
  width: 380rpx;
  height: 380rpx;
  border-radius: 24rpx;
  object-fit: cover;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.1);
  margin-bottom: 24rpx;
}

.dish-name {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #2d6a4f;
  margin-bottom: 12rpx;
}

.dish-tag {
  display: inline-block;
  font-size: 24rpx;
  background-color: #d8f3dc;
  color: #40916c;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.empty-tip {
  height: 100%;
  font-size: 32rpx;
  color: #74c69d;
}

.btn-section {
  text-align: center;
  margin: 40rpx 0;
  position: relative;
  z-index: 1;
}

.roll-btn {
  width: 400rpx;
  height: 90rpx;
  line-height: 90rpx;
  font-size: 34rpx;
  margin-bottom: 20rpx;
}

.again-btn {
  width: 280rpx;
  height: 70rpx;
  line-height: 70rpx;
  font-size: 28rpx;
}

.today-record {
  position: relative;
  z-index: 1;
}

.record-header {
  margin-bottom: 20rpx;
}

.record-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2d6a4f;
}

.record-date {
  font-size: 24rpx;
  color: #74c69d;
}

.record-dish {
  margin-top: 16rpx;
}

.record-info {
  gap: 20rpx;
}

.record-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  object-fit: cover;
}

.record-name {
  font-size: 30rpx;
  color: #333;
}

.change-btn {
  height: 60rpx;
  line-height: 60rpx;
  font-size: 24rpx;
  padding: 0 30rpx;
}

.history-section {
  position: relative;
  z-index: 1;
}

.history-title {
  display: block;
  font-size: 28rpx;
  color: #2d6a4f;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.history-scroll {
  white-space: nowrap;
}

.history-item {
  display: inline-block;
  width: 140rpx;
  margin-right: 24rpx;
  text-align: center;
}

.history-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  object-fit: cover;
  margin-bottom: 8rpx;
}

.history-name {
  display: block;
  font-size: 24rpx;
  color: #555;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.guide-tip {
  text-align: center;
  margin: 40rpx 60rpx;
  padding: 30rpx;
  background-color: #d8f3dc;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #2d6a4f;
  position: relative;
  z-index: 1;
}

.add-link {
  display: inline-block;
  color: #1b4332;
  font-weight: 600;
  margin-left: 10rpx;
  border-bottom: 2rpx solid #2d6a4f;
}

/* 选菜动画效果 */
.rolling .dish-image {
  animation: rotate 0.1s linear infinite;
}

@keyframes rotate {
  0% { transform: scale(0.95); }
  50% { transform: scale(1.05); }
  100% { transform: scale(0.95); }
}
