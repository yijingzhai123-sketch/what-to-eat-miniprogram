/* 菜品列表页面样式 */
page {
  height: 100%;
  background-color: #f0f9f4;
}
.container {
  min-height: 100vh;
  padding: 20rpx 0 calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* 统计卡片 */
.stats-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 30rpx 20rpx;
  margin: 20rpx 24rpx 24rpx 24rpx;
  width: auto;
  box-sizing: border-box;
}

.stats-item {
  flex-direction: column;
  gap: 8rpx;
}

.stats-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #2d6a4f;
}

.stats-label {
  font-size: 24rpx;
  color: #74c69d;
}

.stats-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: #d8f3dc;
}

/* 筛选区域 */
.filter-section {
  padding: 0 24rpx;
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.tag-scroll {
  white-space: nowrap;
  width: 100%;
}

.filter-tag {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  background-color: white;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #555;
  box-shadow: 0 2rpx 8rpx rgba(136, 201, 163, 0.1);
}

.filter-tag.active {
  background: linear-gradient(135deg, #88c9a3 0%, #5ab47e 100%);
  color: white;
}

/* 菜品列表 */
.dish-list {
  width: 100%;
  box-sizing: border-box;
}
.dish-item {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  margin: 0 24rpx 24rpx 24rpx;
  width: auto;
  box-sizing: border-box;
}

.item-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 20rpx;
  object-fit: cover;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.item-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.item-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d6a4f;
}

.item-tag {
  font-size: 22rpx;
  background-color: #d8f3dc;
  color: #40916c;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.item-remark {
  font-size: 24rpx;
  color: #777;
  line-height: 1.4;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.item-actions {
  display: flex;
  gap: 16rpx;
  justify-content: flex-start;
}

.action-btn {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  margin: 0;
  line-height: 1.4;
  min-height: auto;
  height: auto;
}

.choose-btn {
  background-color: #52b788;
  color: white;
}

.delete-btn {
  background-color: white;
  color: #e63946;
  border: 2rpx solid #ffccd5;
}

/* 空状态 */
.empty-state {
  flex-direction: column;
  padding-top: 200rpx;
  gap: 24rpx;
}

.empty-icon {
  font-size: 120rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #74c69d;
}

.add-btn {
  margin-top: 20rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
}
