<!-- 菜品列表页面 -->
<view class="container">
  <!-- 统计信息 -->
  <view class="stats-card card">
    <view class="stats-item flex-center">
      <text class="stats-num">{{dishList.length}}</text>
      <text class="stats-label">总菜品</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item flex-center">
      <text class="stats-num">{{tagCount}}</text>
      <text class="stats-label">个分类</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item flex-center">
      <text class="stats-num">{{cookedCount}}</text>
      <text class="stats-label">吃过的</text>
    </view>
  </view>

  <!-- 分类筛选 -->
  <view class="filter-section">
    <scroll-view scroll-x="true" class="tag-scroll">
      <view class="filter-tag {{currentTag === '' ? 'active' : ''}}" bindtap="filterTag" data-tag="">
        全部
      </view>
      <view class="filter-tag {{currentTag === tag ? 'active' : ''}}" wx:for="{{tagList}}" wx:key="index" bindtap="filterTag" data-tag="{{tag}}">
        {{tag}}
      </view>
    </scroll-view>
  </view>

  <!-- 菜品列表 -->
  <view class="dish-list" wx:if="{{filterList.length > 0}}">
    <view class="dish-item card" wx:for="{{filterList}}" wx:key="id">
      <image class="item-img" src="{{item.image}}" mode="aspectFill"></image>
      <view class="item-info">
        <view class="item-header">
          <text class="item-name">{{item.name}}</text>
          <text class="item-tag" wx:if="{{item.tag}}">{{item.tag}}</text>
        </view>
        <text class="item-remark" wx:if="{{item.remark}}">{{item.remark}}</text>
        <view class="item-actions">
          <button class="action-btn choose-btn" bindtap="chooseThis" data-dish="{{item}}">就吃它</button>
          <button class="action-btn delete-btn" bindtap="deleteDish" data-id="{{item.id}}">删除</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state flex-center" wx:else>
    <text class="empty-icon">🍜</text>
    <text class="empty-text">还没有添加菜品哦，快去添加你爱吃的菜吧~</text>
    <navigator url="/pages/add/add" class="add-btn btn-primary">去添加菜品</navigator>
  </view>
</view>
