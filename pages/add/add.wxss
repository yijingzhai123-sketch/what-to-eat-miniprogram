/* 添加菜品页面样式 */
.container {
  padding: 20rpx 0;
}

.add-card {
  margin-top: 20rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #2d6a4f;
  margin-bottom: 20rpx;
}

.required {
  color: #e63946;
}

/* 图片上传区域 */
.upload-section {
  margin-bottom: 40rpx;
}

.upload-area {
  width: 100%;
  height: 360rpx;
  background-color: #f0f9f4;
  border: 3rpx dashed #95d5b2;
  border-radius: 24rpx;
  overflow: hidden;
}

.preview-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.upload-placeholder {
  width: 100%;
  height: 100%;
  flex-direction: column;
  gap: 16rpx;
}

.plus-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #95d5b2;
  color: white;
  font-size: 48rpx;
  line-height: 80rpx;
  text-align: center;
}

.upload-tip {
  font-size: 28rpx;
  color: #52b788;
}

/* 输入区域 */
.input-section {
  margin-bottom: 40rpx;
}

.input-field {
  width: 100%;
  height: 80rpx;
  background-color: #f8fbf9;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  border: 2rpx solid #d8f3dc;
}

.textarea-field {
  width: 100%;
  min-height: 120rpx;
  background-color: #f8fbf9;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 2rpx solid #d8f3dc;
  line-height: 1.5;
}

/* 标签区域 */
.tag-section {
  margin-bottom: 40rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  padding: 12rpx 28rpx;
  background-color: #f0f9f4;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #40916c;
  border: 2rpx solid #d8f3dc;
}

.tag-item.active {
  background-color: #52b788;
  color: white;
  border-color: #52b788;
}

.tag-input {
  flex: 1;
  min-width: 180rpx;
  height: 56rpx;
  padding: 0 20rpx;
  background-color: #f8fbf9;
  border-radius: 40rpx;
  font-size: 26rpx;
  border: 2rpx solid #d8f3dc;
}

.custom-tag {
  border-style: dashed;
}

.save-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  font-size: 32rpx;
  margin-top: 20rpx;
}

.tip-card {
  margin: 30rpx 24rpx;
  padding: 24rpx;
  background-color: #d8f3dc;
  border-radius: 16rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #2d6a4f;
  line-height: 1.6;
}
